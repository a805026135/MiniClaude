# MiMo API Configuration
MINICLAUDE_API_KEY=your-api-key-here
MINICLAUDE_API_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
MINICLAUDE_MODEL=mimo-v2.5-pro

# Model parameters
MINICLAUDE_MAX_TOKENS=8192
MINICLAUDE_TEMPERATURE=0.6

# Context limits
MINICLAUDE_CONTEXT_LIMIT=131072
MINICLAUDE_EXTERNALIZE_THRESHOLD=2000

# Security
MINICLAUDE_ALLOW_SHELL=true
MINICLAUDE_CONFIRM_DANGEROUS=true
MINICLAUDE_PROJECT_DIR=

# Memory
MINICLAUDE_MEMORY_DB=data/memory/miniclaude.db
MINICLAUDE_MEMORY_ENABLED=true

# Logging
MINICLAUDE_LOG_LEVEL=INFO
